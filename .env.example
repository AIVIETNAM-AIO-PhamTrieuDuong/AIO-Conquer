# =============================================================
# OpenAI-compatible LLM endpoint
# Dùng một trong hai cách bên dưới, xoá comment dòng tương ứng
# =============================================================

# --- Cách 1: OpenAI trực tiếp ---
# NINEROUTER_URL=https://api.openai.com/v1
# NINEROUTER_KEY=sk-...
# NINEROUTER_MODEL=gpt-4o

# --- Cách 2: 9Router (hoặc provider OpenAI-compatible khác) ---
NINEROUTER_URL=http://45.128.222.24:20128/v1
NINEROUTER_MODEL=ragas_experiments
# NINEROUTER_KEY=your-key-if-required

# =============================================================
# Redis
# =============================================================
# Host ports khớp với docker-compose.yml. Dùng 7379/7380/7381 vì
# 6379-6381 nằm trong dải port bị Windows/Hyper-V (WinNAT) reserve.
REDIS_URL=redis://localhost:7379
REDIS_VECTOR_URL=redis://localhost:7380
REDIS_DOMAIN_URL=redis://localhost:7381
REDIS_VECTOR_INDEX=aio_conquer_vector_memory
SESSION_TTL=3600
MAX_HISTORY_TURNS=5

# =============================================================
# Pinecone (bỏ trống để tắt retrieval)
# =============================================================
PINECONE_API_KEY=
PINECONE_INDEX=

# =============================================================
# Embedding model (OpenAI embedding)
# =============================================================
EMBED_MODEL=text-embedding-3-small

# =============================================================
# LangSmith tracing (observability)
# Đặt LANGSMITH_TRACING=true và điền API key để bật tracing.
# Lấy API key tại https://smith.langchain.com (Settings -> API Keys).
# Các biến này được nạp vào os.environ tại app/core/tracing.py để
# LangChain ChatOpenAI và các hàm @traceable tự động log trace.
# =============================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT=aio
# Chỉ cần khi API key gắn với nhiều workspace:
# LANGSMITH_WORKSPACE_ID=
