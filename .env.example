# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Redis
REDIS_URL=redis://localhost:6379
SESSION_TTL=3600
MAX_HISTORY_TURNS=5

# Pinecone (optional — skip to disable retrieval)
PINECONE_API_KEY=
PINECONE_INDEX=

# Embedding
EMBED_MODEL=text-embedding-004
