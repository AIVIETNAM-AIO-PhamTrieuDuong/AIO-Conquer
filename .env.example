# =============================================================
# OpenAI-compatible LLM endpoint
# Dùng một trong hai cách bên dưới, xoá comment dòng tương ứng
# =============================================================

# --- Cách 1: OpenAI trực tiếp ---
# NINEROUTER_URL=https://api.openai.com/v1
# NINEROUTER_KEY=sk-...
# NINEROUTER_MODEL=gpt-4o

# --- Cách 2: 9Router (hoặc provider OpenAI-compatible khác) ---
NINEROUTER_URL=http://45.128.222.24:20128/v1
NINEROUTER_MODEL=ragas_experiments
# NINEROUTER_KEY=your-key-if-required

# =============================================================
# Redis
# =============================================================
REDIS_URL=redis://localhost:6379
SESSION_TTL=3600
MAX_HISTORY_TURNS=5

# =============================================================
# Pinecone (bỏ trống để tắt retrieval)
# =============================================================
PINECONE_API_KEY=
PINECONE_INDEX=

# =============================================================
# Embedding model (OpenAI embedding)
# =============================================================
EMBED_MODEL=text-embedding-3-small

# LangSmith tracing
# This example uses OpenAI, but you can use any LLM provider of choice
# For LangSmith API keys linked to multiple workspaces, set the LANGSMITH_WORKSPACE_ID environment variable to specify which workspace to use.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="aio"